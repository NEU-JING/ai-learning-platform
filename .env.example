# AI学习平台 - 生产环境配置文件示例
# 复制此文件为 .env 并填写实际值

# ==========================================
# 数据库配置 (PostgreSQL)
# ==========================================
DB_NAME=ailearning
DB_USER=ailearning
# ⚠️ 重要: 必须修改为强密码！
# 生成命令: openssl rand -base64 32
DB_PASSWORD=your-secure-db-password-here

# ==========================================
# Redis缓存配置
# ==========================================
# ⚠️ 重要: 必须修改为强密码！
REDIS_PASSWORD=your-secure-redis-password-here

# ==========================================
# JWT安全密钥
# ==========================================
# ⚠️ 重要: 生产环境必须设置强密钥！
# 生成命令: openssl rand -hex 32
SECRET_KEY=your-256-bit-secret-key-here-change-in-production

# Token过期时间(分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# CORS跨域配置
# ==========================================
# 生产环境: 设置你的实际域名
# 多个域名用逗号分隔，例如: https://app.example.com,https://admin.example.com
CORS_ORIGINS=https://your-domain.com

# ==========================================
# 监控配置 (Grafana)
# ==========================================
GRAFANA_PASSWORD=your-grafana-admin-password
# Grafana根URL
GRAFANA_ROOT_URL=https://your-domain.com/grafana

# ==========================================
# SSL/Let's Encrypt配置
# ==========================================
# Let's Encrypt证书申请邮箱
LETSENCRYPT_EMAIL=admin@your-domain.com
# 域名
LETSENCRYPT_DOMAIN=your-domain.com

# ==========================================
# 可选: 沙箱配置
# ==========================================
SANDBOX_TIMEOUT=30
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1.0

# ==========================================
# 可选: 应用配置
# ==========================================
APP_NAME="AI Learning Platform"
LOG_LEVEL=INFO

# ==========================================
# 提示
# ==========================================
# 1. 修改所有标注 ⚠️ 的密码和密钥
# 2. 将 CORS_ORIGINS 改为你的实际域名
# 3. 如果使用Let's Encrypt，设置正确的邮箱和域名
# 4. 完成后运行: ./deploy.sh deploy
