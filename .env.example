# AI学习平台 - 环境变量模板
# 复制为 .env 并修改后使用

# ==================== 数据库配置 ====================
DB_NAME=ailearning
DB_USER=ailearning
# 重要：生产环境必须使用强密码！
DB_PASSWORD=change_me_in_production

# ==================== Redis配置 ====================
# 重要：生产环境必须使用强密码！
REDIS_PASSWORD=change_me_in_production

# ==================== JWT配置 ====================
# 重要：生产环境必须修改！至少32位随机字符串
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==================== 应用配置 ====================
ENVIRONMENT=production
LOG_LEVEL=INFO
APP_NAME=AI学习平台
VERSION=1.0.0

# ==================== 沙箱配置 ====================
SANDBOX_URL=http://sandbox:8080
SANDBOX_TIMEOUT=30
MAX_MEMORY=512m
MAX_CPU=1.0

# ==================== 监控配置 ====================
GRAFANA_PASSWORD=change_me_in_production

# ==================== 邮件配置（可选）================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=AI学习平台 <noreply@example.com>

# ==================== 存储配置（可选）================
# 如果使用云存储
# STORAGE_TYPE=local  # local/s3/oss
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
