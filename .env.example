# AI Learning Platform — Production Environment Variables
# Copy this to .env and customize before deploying

# Required — generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-at-least-32-characters

# Database
DATABASE_URL=postgresql://ailp:ailp_secret@postgres:5432/ailp

# Redis
REDIS_URL=redis://redis:6379/0

# CORS — comma-separated origins, or * for any
CORS_ORIGINS=*

# Postgres credentials (used by docker-compose for the postgres service)
POSTGRES_USER=ailp
POSTGRES_PASSWORD=ailp_secret
POSTGRES_DB=ailp
